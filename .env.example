# =============================================================================
# Cloudreve-EO 环境变量示例
# 复制为 .env 后按需修改（.env 已被 git 忽略，勿提交真实密钥）
#
# 本地：edgeone makers env pull 也会生成/更新 .env
# 线上：edgeone makers env set <KEY> <VALUE>
#
# 说明：仅「基础设施」走环境变量。JWT 主密钥、S3 存储策略、每策略配额、
# 注册开关等业务配置一律在前端写入数据库，不在此配置。
# =============================================================================

# -----------------------------------------------------------------------------
# 服务端口
# - EdgeOne / Makers 运行时通常会注入 PORT，一般无需手写
# - config 默认：8080；api.go 入口未设置时回退 9000
# -----------------------------------------------------------------------------
PORT=8080

# -----------------------------------------------------------------------------
# 数据库
# DB_DRIVER: sqlite | postgres
# DB_DSN:
#   - sqlite：相对/绝对文件路径（EdgeOne 本地盘无状态，重部署可能清空）
#   - postgres：标准 DSN 连接串
# -----------------------------------------------------------------------------
DB_DRIVER=sqlite
DB_DSN=cloudreve.db

# --- PostgreSQL 示例（生产推荐）---
# DB_DRIVER=postgres
# DB_DSN=host=127.0.0.1 user=cloudreve password=secret dbname=cloudreve port=5432 sslmode=disable
#
# 云托管示例（ssl 常开）：
# DB_DSN=host=xxx.postgres.database.azure.com user=cloudreve password=xxx dbname=cloudreve port=5432 sslmode=require

# =============================================================================
# 以下变量「不会」被应用读取，请勿依赖（历史/误配对照）
# =============================================================================
# JWT_SECRET=...          # 不支持：JWT 在库中自动生成，管理员可在「参数设置」轮转
# DEFAULT_QUOTA=...       # 不支持：配额按每个存储策略的 default_quota 配置
# DEFAULT_STORAGE=...     # 不支持：存储策略在前端「存储策略」页管理
# S3_ENDPOINT / S3_*      # 不支持：同上，多策略凭证写库
